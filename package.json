{
  "name": "@diagrammo/dgmo-mcp",
  "version": "0.1.17",
  "description": "MCP server for rendering DGMO diagrams — SVG/PNG output, browser preview, HTML reports, and 35+ chart types. Works with Claude Desktop, Claude Code, and any MCP client.",
  "keywords": [
    "mcp",
    "mcp-server",
    "diagrams",
    "svg",
    "charts",
    "sequence-diagram",
    "flowchart",
    "diagrammo",
    "dgmo",
    "claude",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/diagrammo/dgmo-mcp.git"
  },
  "homepage": "https://github.com/diagrammo/dgmo-mcp#readme",
  "mcpName": "io.github.diagrammo/dgmo-mcp",
  "bin": {
    "dgmo-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsup src/index.ts --format cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "bundle": "bash scripts/bundle.sh",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {
    "@diagrammo/dgmo": "^0.12.0",
    "@modelcontextprotocol/sdk": "^1.12.1",
    "@resvg/resvg-js": "^2.6.2",
    "jsdom": "^29.0.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@types/node": "^22.0.0",
    "tsup": "^8.4.0",
    "typescript": "^5.7.0"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
