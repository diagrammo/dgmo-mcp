{
  "name": "@diagrammo/dgmo-mcp",
  "version": "0.2.5",
  "description": "MCP server for rendering DGMO diagrams — SVG/PNG output, browser preview, HTML reports, and 35+ chart types. Works with Claude Desktop, Claude Code, and any MCP client.",
  "keywords": [
    "mcp",
    "mcp-server",
    "diagrams",
    "svg",
    "charts",
    "sequence-diagram",
    "flowchart",
    "diagrammo",
    "dgmo",
    "claude",
    "ai"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/diagrammo/dgmo-mcp.git"
  },
  "homepage": "https://github.com/diagrammo/dgmo-mcp#readme",
  "engines": {
    "node": ">=20.6"
  },
  "mcpName": "io.github.diagrammo/dgmo-mcp",
  "bin": {
    "dgmo-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "scripts": {
    "build": "tsup src/index.ts --format cjs --dts",
    "dev": "tsup src/index.ts --format cjs --dts --watch",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "bundle": "bash scripts/bundle.sh",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:deadcode": "knip",
    "check:duplication": "jscpd ./src",
    "check:deps": "depcheck --ignores='jsdom,@anthropic-ai/mcpb'",
    "check:all": "pnpm check:deadcode && pnpm check:duplication && pnpm check:deps && pnpm test",
    "prepare": "git config core.hooksPath .githooks 2>/dev/null || true"
  },
  "dependencies": {
    "@diagrammo/dgmo": "^0.28.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@resvg/resvg-js": "^2.6.2",
    "jsdom": "^29.1.1",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@anthropic-ai/mcpb": "^2.1.2",
    "@eslint/js": "^10.0.1",
    "@types/node": "^24.0.0",
    "@vitest/coverage-v8": "^4.1.8",
    "depcheck": "^1.4.7",
    "eslint": "^10.4.1",
    "jscpd": "^4.2.4",
    "knip": "^6.15.0",
    "prettier": "^3.8.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.8"
  },
  "files": [
    "dist"
  ],
  "license": "MIT"
}
