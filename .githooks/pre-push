#!/usr/bin/env bash
# Runs preflight.sh on tag push. Stops a bad release from leaving the machine.
#
# Activated via `git config core.hooksPath .githooks` (the `prepare` npm script
# in package.json sets this automatically after `pnpm install`).
#
# Bypass in emergencies with `git push --no-verify`.

set -e

ZERO_SHA="0000000000000000000000000000000000000000"

# git feeds one line per ref being pushed: <local ref> <local sha> <remote ref> <remote sha>
while read -r local_ref local_sha _remote_ref _remote_sha; do
  # Only care about tag pushes (not branch pushes, not tag deletions)
  if [[ "$local_ref" == refs/tags/* && "$local_sha" != "$ZERO_SHA" ]]; then
    tag="${local_ref#refs/tags/}"
    printf "\033[1;34m→ tag push detected (%s) — running preflight\033[0m\n" "$tag"
    bash "$(git rev-parse --show-toplevel)/preflight.sh"
    # Loop continues — if multiple tags are pushed in one command, we only need
    # preflight to pass once (working tree is the same for all of them).
    exit 0
  fi
done

# No tag refs; let the push proceed.
exit 0
